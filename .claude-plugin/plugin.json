{
  "name": "@cyanheads/pixoo-mcp-server",
  "version": "1.0.0",
  "description": "Render and push styled pixel art, text, dashboards, and animations to Divoom Pixoo LED displays on your local network via MCP. STDIO or Streamable HTTP.",
  "author": {
    "name": "cyanheads"
  },
  "homepage": "https://github.com/cyanheads/pixoo-mcp-server#readme",
  "repository": "git+https://github.com/cyanheads/pixoo-mcp-server.git",
  "license": "Apache-2.0",
  "mcpServers": {
    "@cyanheads/pixoo-mcp-server": {
      "command": "npx",
      "args": [
        "-y",
        "@cyanheads/pixoo-mcp-server"
      ],
      "env": {
        "MCP_TRANSPORT_TYPE": "stdio"
      }
    }
  }
}
