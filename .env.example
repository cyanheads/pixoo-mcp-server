# -----------------------------------------------------------------
# Pixoo Device Configuration
# -----------------------------------------------------------------

# IP address of the Pixoo device on the local network (required)
PIXOO_IP=192.168.1.100

# Display resolution: 16, 32, or 64 (default: 64)
PIXOO_SIZE=64

# Directory for auto-saved preview images (default: output/)
# PIXOO_OUTPUT_DIR=output/

# -----------------------------------------------------------------
# MCP Server Configuration
# -----------------------------------------------------------------

# Transport type: "stdio" or "http"
MCP_TRANSPORT_TYPE=stdio

# Session mode: "stateless", "stateful", or "auto" (only used if MCP_TRANSPORT_TYPE=http)
MCP_SESSION_MODE=auto

# Log level: "trace", "debug", "info", "warn", "error", "fatal", "silent"
MCP_LOG_LEVEL=debug

# Directory for log files
LOGS_DIR=logs/

# -----------------------------------------------------------------
# HTTP Transport Configuration (only used if MCP_TRANSPORT_TYPE=http)
# -----------------------------------------------------------------

MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3010

# Comma-separated list of allowed origins for CORS
MCP_ALLOWED_ORIGINS=http://localhost:8080

# -----------------------------------------------------------------
# Storage Configuration
# -----------------------------------------------------------------
# The storage provider to use. Options: "in-memory", "filesystem"
STORAGE_PROVIDER_TYPE="in-memory"
