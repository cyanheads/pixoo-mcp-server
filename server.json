{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.cyanheads/pixoo-mcp-server",
  "description": "MCP server for pushing visual content to Divoom Pixoo RGB LED matrix displays over the local network.",
  "repository": {
    "url": "https://github.com/cyanheads/pixoo-mcp-server",
    "source": "github"
  },
  "version": "0.1.0",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "pixoo-mcp-server",
      "runtimeHint": "bun",
      "version": "0.1.0",
      "packageArguments": [
        {
          "type": "positional",
          "value": "run"
        },
        {
          "type": "positional",
          "value": "start:stdio"
        }
      ],
      "environmentVariables": [
        {
          "name": "PIXOO_IP",
          "description": "IP address of the Pixoo device on the local network.",
          "format": "string",
          "isRequired": true
        },
        {
          "name": "PIXOO_SIZE",
          "description": "Display resolution: 16, 32, or 64.",
          "format": "string",
          "isRequired": false,
          "default": "64"
        },
        {
          "name": "MCP_LOG_LEVEL",
          "description": "Sets the minimum log level for output (e.g., 'debug', 'info', 'warn').",
          "format": "string",
          "isRequired": false,
          "default": "info"
        }
      ],
      "transport": {
        "type": "stdio"
      }
    },
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "pixoo-mcp-server",
      "runtimeHint": "bun",
      "version": "0.1.0",
      "packageArguments": [
        {
          "type": "positional",
          "value": "run"
        },
        {
          "type": "positional",
          "value": "start:http"
        }
      ],
      "environmentVariables": [
        {
          "name": "PIXOO_IP",
          "description": "IP address of the Pixoo device on the local network.",
          "format": "string",
          "isRequired": true
        },
        {
          "name": "PIXOO_SIZE",
          "description": "Display resolution: 16, 32, or 64.",
          "format": "string",
          "isRequired": false,
          "default": "64"
        },
        {
          "name": "MCP_HTTP_HOST",
          "description": "The hostname for the HTTP server.",
          "format": "string",
          "isRequired": false,
          "default": "127.0.0.1"
        },
        {
          "name": "MCP_HTTP_PORT",
          "description": "The port to run the HTTP server on.",
          "format": "string",
          "isRequired": false,
          "default": "3010"
        },
        {
          "name": "MCP_LOG_LEVEL",
          "description": "Sets the minimum log level for output (e.g., 'debug', 'info', 'warn').",
          "format": "string",
          "isRequired": false,
          "default": "info"
        }
      ],
      "transport": {
        "type": "streamable-http",
        "url": "http://localhost:3010/mcp"
      }
    }
  ]
}
