exports[`Tool Schema Snapshots > Tool: pixoo_compose > outputSchema JSON output should be stable 1`] = `
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "description": "Result of the compose operation.",
  "properties": {
    "frames": {
      "description": "Number of frames rendered.",
      "type": "number",
    },
    "outputFiles": {
      "description": "Paths of saved preview PNGs.",
      "items": {
        "type": "string",
      },
      "type": "array",
    },
    "pushed": {
      "description": "Whether the result was pushed to the device.",
      "type": "boolean",
    },
  },
  "required": [
    "frames",
    "pushed",
  ],
  "type": "object",
}
`;

exports[`Tool Schema Snapshots > Tool: pixoo_control > inputSchema JSON output should be stable 1`] = `
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "description": "Read or change Pixoo device settings.",
  "properties": {
    "brightness": {
      "description": "Display brightness (0–100).",
      "maximum": 100,
      "minimum": 0,
      "type": "integer",
    },
    "channel": {
      "description": "Active channel ('faces' | 'cloud' | 'visualizer' | 'custom').",
      "enum": [
        "faces",
        "cloud",
        "visualizer",
        "custom",
      ],
      "type": "string",
    },
    "clock_face_id": {
      "description": "Clock face ID (only applies on faces channel).",
      "maximum": 9007199254740991,
      "minimum": 0,
      "type": "integer",
    },
    "screen": {
      "description": "Turn display on or off ('on' | 'off').",
      "enum": [
        "on",
        "off",
      ],
      "type": "string",
    },
  },
  "type": "object",
}
`;

exports[`Tool Schema Snapshots > Tool: pixoo_control > outputSchema JSON output should be stable 1`] = `
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "description": "Current device config after applying any changes.",
  "properties": {
    "applied": {
      "description": "List of settings that were changed.",
      "items": {
        "type": "string",
      },
      "type": "array",
    },
    "brightness": {
      "description": "Current brightness (0–100).",
      "type": "number",
    },
    "channel": {
      "description": "Current active channel name.",
      "type": "string",
    },
    "channelIndex": {
      "description": "Current active channel index.",
      "type": "number",
    },
    "clockId": {
      "description": "Current clock face ID.",
      "type": "number",
    },
    "screenOn": {
      "description": "Whether the display is on.",
      "type": "boolean",
    },
  },
  "required": [
    "brightness",
    "channel",
    "channelIndex",
