}
`;

exports[`Tool Schema Snapshots > Tool: pixoo_push_image > inputSchema JSON output should be stable 1`] = `
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "description": "Push a single image to the Pixoo display.",
  "properties": {
    "fit": {
      "default": "contain",
      "description": "Resize mode: 'contain' (default, fit within bounds), 'cover' (fill and crop), 'fill' (stretch).",
      "enum": [
        "contain",
        "cover",
        "fill",
      ],
      "type": "string",
    },
    "kernel": {
      "default": "nearest",
      "description": "Resize interpolation: 'nearest' (default, pixel art), 'lanczos3' (photos), 'mitchell' (balanced).",
      "enum": [
        "nearest",
        "lanczos3",
        "mitchell",
      ],
      "type": "string",
    },
    "path": {
      "description": "Absolute path to image file (PNG, JPEG, WebP, GIF, AVIF, TIFF, SVG).",
      "minLength": 1,
      "type": "string",
    },
  },
  "required": [
    "path",
    "fit",
    "kernel",
  ],
  "type": "object",
}
`;

